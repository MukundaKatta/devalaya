{
  "expo": {
    "name": "Devalaya Admin",
    "slug": "devalaya-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "devalaya-admin",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.devalaya.admin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "org.devalaya.admin"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
